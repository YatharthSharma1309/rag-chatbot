# Copy to .env.local and fill in real values (never commit .env.local).

# ── Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_public_JWT...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_secret_JWT...
# Dashboard → Authentication → Providers: enable Email.
# Dashboard → Authentication → URL configuration: Site URL = http://localhost:3000 (or prod URL).
# Add Redirect URLs (exact): http://localhost:3000/auth/callback and your production /auth/callback.
# Providers → Google: enable and paste OAuth Client ID + Secret from Google Cloud Console.

# Encrypts per-user OpenRouter keys at rest (server only). Use a long random secret, e.g.:
#   openssl rand -base64 32
USER_SETTINGS_ENCRYPTION_KEY=change-this-to-a-long-random-secret-min-24-chars

# Used in OpenRouter headers (optional but recommended for production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Embeddings — pick ONE of the two options below:

# Option A (FREE, recommended): Jina AI — 1M tokens/month free, no credit card
# Sign up at https://jina.ai to get your free key
# Uses jina-embeddings-v2-base-en (768 dims)
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B (paid): OpenAI — requires a paid API key
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server fallback (optional) — chat model + key now come from each signed-in user (OpenRouter).
# These are NOT used for end-user chat when users have saved keys; keep for embeddings / local scripts.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_CHAT_MODEL=openai/gpt-oss-20b:free

# ── Playwright (optional)
# PLAYWRIGHT_SKIP_WEBSERVER=1   # if you already run `npm run dev` separately
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
