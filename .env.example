# Copy to .env.local and fill in real values (never commit .env.local).

# ── Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_secret_JWT...

# ── Embeddings — pick ONE of the two options below:

# Option A (FREE, recommended): Jina AI — 1M tokens/month free, no credit card
# Sign up at https://jina.ai to get your free key
# Uses jina-embeddings-v2-base-en (768 dims)
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B (paid): OpenAI — requires a paid API key
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Chat completions — pick ONE:

# Option A (FREE): OpenRouter — use free models (Llama, Gemma, etc.)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free   ← default when OPENROUTER_API_KEY is set
# OPENAI_CHAT_MODEL=google/gemma-3-27b-it:free              ← alternative

# Option B (paid): OpenAI directly
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_CHAT_MODEL=gpt-4o-mini
